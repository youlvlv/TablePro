    "Network is unavailable. Changes will sync when connectivity is restored." : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ağ kullanılamıyor. Bağlantı sağlandığında değişiklikler eşitlenecek."
          }
