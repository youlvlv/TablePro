    "This driver has no TLS fallback. Preferred forces TLS, same as Required." : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu sürücünün TLS yedeği yok. Preferred, Required ile aynı şekilde TLS'yi zorunlu kılar."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Driver này không có phương án dự phòng TLS. Preferred buộc dùng TLS, giống Required."
