        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用 {{query}} 表示当前编辑器查询，{{schema}} 表示活动 Schema，{{database}} 表示活动数据库名称，{{body}} 表示命令后输入的任意文本。"
