          "stringUnit" : {
            "state" : "translated",
            "value" : "API 密钥将被永久删除。"
          }
        }
      }
    },
    "The authenticity of host '%@' can't be established.\n\n%@ key fingerprint is:\n%@\n\nAre you sure you want to continue connecting?" : {
      "localizations" : {
