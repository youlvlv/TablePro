        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$lld truy vấn sau có thể thay đổi hoặc xóa dữ liệu vĩnh viễn. Hành động này không thể hoàn tác.\n\n%2$@"
