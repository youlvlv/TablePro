    },
    "This discards your edits to the Chinook sample and restores the original copy." : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu, Chinook örneğindeki düzenlemelerinizi atar ve özgün kopyayı geri yükler."
