    "Connection is read-only. Destructive operations are not permitted." : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bağlantı salt okunur. Yıkıcı işlemlere izin verilmez."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kết nối chỉ đọc. Không cho phép các thao tác phá hủy."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
