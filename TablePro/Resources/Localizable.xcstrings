    "Signs in to Cloudflare Access once and caches the token, so connecting doesn't open a browser." : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cloudflare Access'e bir kez giriş yapar ve jetonu önbelleğe alır, böylece bağlanırken tarayıcı açılmaz."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Đăng nhập Cloudflare Access một lần và lưu token vào bộ nhớ đệm, nên khi kết nối sẽ không mở trình duyệt."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "登录 Cloudflare Access 一次并缓存令牌，连接时不再打开浏览器。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "登入 Cloudflare Access 一次並快取權杖，這樣連線時就不會開啟瀏覽器。"
          }
        }
      }
    },
