          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mỗi tệp SQLite là một cơ sở dữ liệu riêng.\nĐể mở cơ sở dữ liệu khác, hãy tạo kết nối mới."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
