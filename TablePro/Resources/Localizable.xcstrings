        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将删除提供商配置和已存储的 API 密钥。"
          }
        }
      }
    },
    "The selected backup file is not readable." : {
      "localizations" : {
        "tr" : {
