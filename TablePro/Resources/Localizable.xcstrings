    },
    "The partial backup file will be removed." : {
      "comment" : "A message displayed in a cancel confirmation alert for a backup.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
