          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "File sao lưu dở dang sẽ bị xóa."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未完成的备份文件将被移除。"
          }
        }
      }
    },
    "The password source produced an empty password" : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parola kaynağı boş bir parola döndürdü"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nguồn mật khẩu trả về mật khẩu rỗng"
